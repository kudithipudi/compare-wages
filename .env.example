OPENROUTER_API_KEY=
# Default model — used as fallback if a per-purpose model isn't configured (env or DB).
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# Per-purpose model overrides (optional). Admin UI at /admin/llm-models overrides these.
EXTRACTION_MODEL=anthropic/claude-3.5-haiku
CLASSIFICATION_MODEL=openai/gpt-4o-mini
NARRATIVE_MODEL=anthropic/claude-3.5-sonnet
USE_MOCK_LLM=true
DATABASE_URL=sqlite:///./data/wages.db
DISTANCE_CUTOFF_MILES=25
# Sub-path prefix when reverse-proxied (e.g. behind nginx at https://host/compare-wages).
# Leave empty for root mount.
ROOT_PATH=
# Login form credentials for /admin/*. If either is unset, the login form shows an
# explicit "not configured" error and no one can sign in.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Signs the admin session cookie. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
# If empty, a fresh random key is generated on each boot (sessions reset on restart).
SESSION_SECRET=
# Optional: residential proxy for Walmart. Walmart's Akamai+PerimeterX stack
# 403s datacenter IPs. Bright Data / Oxylabs / Smartproxy supply a residential
# pool. Without this set, Walmart falls back to fixtures.
WALMART_PROXY_URL=
WALMART_PROXY_USERNAME=
WALMART_PROXY_PASSWORD=
